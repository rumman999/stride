{
  "importOrder": ["^@", "<THIRD_PARTY_MODULES>", "", "^\\$(?!lib/)", "", "^\\$lib/", "", "^[.]"],
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte"
      }
    }
  ],
  "plugins": [
    "prettier-plugin-svelte",
    "@ianvs/prettier-plugin-sort-imports",
    "prettier-plugin-tailwindcss",
    "prettier-plugin-sort-json"
  ],
  "printWidth": 120,
  "singleQuote": true,
  "tailwindStylesheet": "./src/routes/layout.css",
  "trailingComma": "all",
  "useTabs": false
}
